# Copy this file to .env and fill in your API keys.
# OPENAI_API_KEY is only required when SELECTED_MODEL_KEY is a GPT model.
# All other providers use local embeddings (no OpenAI key needed).

OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
TOGETHER_API_KEY=""


# Optional: LangSmith tracing
LANGCHAIN_TRACING_V2=""
LANGCHAIN_ENDPOINT=""
LANGCHAIN_API_KEY=""
LANGCHAIN_PROJECT=""

# Optional: custom provider base URLs (leave empty to use defaults)
OPENAI_BASE_URL=""
ANTHROPIC_BASE_URL=""
TOGETHER_BASE_URL=""


# Your Linux username — must match the user created in the Docker container.
# If left as "anonymous", the Dockerfile default is used automatically.
UNAME="anonymous"
UID=1000
GID=1000
